---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPeople, getPersonById, getChildren, getSiblings, getSpouses, getParents } from '../../lib/family-data';
import { getResearchForPerson } from '../../lib/markdown-parser';
import path from 'node:path';

export function getStaticPaths() {
  const people = getAllPeople();
  return people.map((person) => ({
    params: { slug: person.slug },
    props: { person },
  }));
}

const { person } = Astro.props;
const parents = getParents(person.id);
const spouses = getSpouses(person.id);
const children = getChildren(person.id);
const siblings = getSiblings(person.id);
const peopleDir = path.resolve('src/data/people');
const research = getResearchForPerson(person.id, peopleDir);

const aliases = person.name.aliases || [];
const yearRange = [person.birthYear, person.deathYear].filter(Boolean).join(' – ');

function personLink(p: { slug: string; fullName: string }) {
  return `<a href="/people/${p.slug}">${p.fullName}</a>`;
}

function mailtoLink(name: string, id: number) {
  const subject = encodeURIComponent(`Family Tree Tip: ${name} (ID ${id})`);
  const body = encodeURIComponent(`I have information about ${name} (ID ${id}):\n\nWhat I found:\n`);
  return `mailto:kevinlfrank@gmail.com?subject=${subject}&body=${body}`;
}

// Parse FamilySearch PIDs from source_citations
function formatCitations(citations: string): string {
  if (!citations) return '';
  return citations.replace(
    /FamilySearch ([A-Z0-9]{4}-[A-Z0-9]{2,4})/g,
    (match, pid) => `<a href="https://www.familysearch.org/tree/person/details/${pid}" target="_blank" rel="noopener">FamilySearch ${pid}</a>`
  );
}
---

<BaseLayout title={person.fullName} description={`${person.fullName} (${yearRange || 'dates unknown'}) — Frank-Miller Family Tree`} pagefindBody={true}>
  <div data-pagefind-meta={`title:${person.fullName}`}>
    <div data-pagefind-filter={`surname:${person.name.last}`}></div>
    {person.birth.place && <div data-pagefind-meta={`location:${person.birth.place}`} class="hidden"></div>}

    <nav class="mb-6 text-sm">
      <a href="/browse">&larr; Back to Browse</a>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-1">{person.fullName}</h1>
      {aliases.length > 0 && (
        <p class="text-earth-500 text-sm">Also known as: {aliases.join(', ')}</p>
      )}
      {yearRange && <p class="text-earth-600 text-lg">{yearRange}</p>}
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="md:col-span-2 space-y-8">
        <!-- Vital Information -->
        <section>
          <h2 class="text-xl font-bold mb-3">Vital Information</h2>
          <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm">
            {person.birth.date && (
              <>
                <dt class="font-semibold text-earth-600">Born</dt>
                <dd>{person.birth.date}{person.birth.place ? `, ${person.birth.place}` : ''}</dd>
              </>
            )}
            {person.death.date && (
              <>
                <dt class="font-semibold text-earth-600">Died</dt>
                <dd>{person.death.date}{person.death.place ? `, ${person.death.place}` : ''}{person.death.cause ? ` (${person.death.cause})` : ''}</dd>
              </>
            )}
            {person.age_at_death && (
              <>
                <dt class="font-semibold text-earth-600">Age at Death</dt>
                <dd>{person.age_at_death}</dd>
              </>
            )}
            {person.occupation && (
              <>
                <dt class="font-semibold text-earth-600">Occupation</dt>
                <dd>{person.occupation}</dd>
              </>
            )}
            {person.residence && (
              <>
                <dt class="font-semibold text-earth-600">Residence</dt>
                <dd>{person.residence}</dd>
              </>
            )}
            {person.burial_place && (
              <>
                <dt class="font-semibold text-earth-600">Burial</dt>
                <dd>{person.burial_place}</dd>
              </>
            )}
          </dl>
        </section>

        <!-- Notes -->
        {person.notes && (
          <section>
            <h2 class="text-xl font-bold mb-3">Notes</h2>
            <p class="text-sm leading-relaxed text-earth-700">{person.notes}</p>
          </section>
        )}

        <!-- Sources -->
        {person.source_citations && (
          <section>
            <h2 class="text-xl font-bold mb-3">Sources</h2>
            <p class="text-sm leading-relaxed text-earth-600" set:html={formatCitations(person.source_citations)} />
          </section>
        )}

        <!-- Research Leads -->
        {research.leads.length > 0 && (
          <section>
            <h2 class="text-xl font-bold mb-3">Research Leads</h2>
            <ul class="space-y-1 text-sm">
              {research.leads.map((lead) => (
                <li class="flex items-start gap-2">
                  <span class="text-earth-400 mt-0.5">☐</span>
                  <span>{lead}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- Research Gaps -->
        {research.gaps.length > 0 && (
          <section>
            <h2 class="text-xl font-bold mb-3">Research Gaps</h2>
            <ul class="space-y-1 text-sm">
              {research.gaps.map((gap) => (
                <li class="flex items-start gap-2">
                  <span class="text-earth-400 mt-0.5">☐</span>
                  <span>{gap}</span>
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>

      <!-- Sidebar: Family Connections -->
      <aside class="space-y-6">
        <div class="bg-earth-100 border border-earth-200 rounded-lg p-4">
          <h2 class="text-lg font-bold mb-4">Family</h2>

          {(parents.father || parents.mother) && (
            <div class="mb-4">
              <h3 class="text-xs font-semibold text-earth-500 uppercase tracking-wide mb-1">Parents</h3>
              <ul class="text-sm space-y-1">
                {parents.father && <li set:html={personLink(parents.father)} />}
                {parents.mother && <li set:html={personLink(parents.mother)} />}
              </ul>
            </div>
          )}

          {spouses.length > 0 && (
            <div class="mb-4">
              <h3 class="text-xs font-semibold text-earth-500 uppercase tracking-wide mb-1">Spouse{spouses.length > 1 ? 's' : ''}</h3>
              <ul class="text-sm space-y-1">
                {spouses.map((s) => <li set:html={personLink(s)} />)}
              </ul>
            </div>
          )}

          {children.length > 0 && (
            <div class="mb-4">
              <h3 class="text-xs font-semibold text-earth-500 uppercase tracking-wide mb-1">Children</h3>
              <ul class="text-sm space-y-1">
                {children.map((c) => <li set:html={personLink(c)} />)}
              </ul>
            </div>
          )}

          {siblings.length > 0 && (
            <div class="mb-4">
              <h3 class="text-xs font-semibold text-earth-500 uppercase tracking-wide mb-1">Siblings</h3>
              <ul class="text-sm space-y-1">
                {siblings.map((s) => <li set:html={personLink(s)} />)}
              </ul>
            </div>
          )}
        </div>

        <a
          href={mailtoLink(person.fullName, person.id)}
          class="block text-center bg-sage-500 hover:bg-sage-600 text-white no-underline rounded-lg px-4 py-2.5 text-sm font-medium transition-colors"
        >
          Submit a Tip
        </a>
      </aside>
    </div>
  </div>
</BaseLayout>
