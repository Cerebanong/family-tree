---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Explore the Tree">
  <h1 class="text-3xl font-bold mb-6">Explore the Family Tree</h1>
  <div id="tree-root" class="min-h-[600px]">
    <p class="text-earth-500 text-center py-16">Loading tree explorer...</p>
  </div>
</BaseLayout>

<script>
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import TreeExplorer from '../components/TreeExplorer';

  const container = document.getElementById('tree-root');
  if (container) {
    container.innerHTML = '';
    const root = createRoot(container);
    root.render(createElement(TreeExplorer));
  }
</script>
