---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div class="text-center py-16">
    <h1 class="text-4xl font-bold mb-4">Page Not Found</h1>
    <p class="text-earth-600 text-lg mb-8">
      The page you're looking for doesn't exist.
    </p>
    <a href="/" class="inline-block bg-sage-500 hover:bg-sage-600 text-white no-underline rounded-lg px-6 py-2.5 text-sm font-medium transition-colors">
      Go to Family Tree
    </a>
  </div>
</BaseLayout>
