---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchWidget from '../components/SearchWidget.astro';
---

<BaseLayout title="Page Not Found">
  <div class="text-center py-16">
    <h1 class="text-4xl font-bold mb-4">Page Not Found</h1>
    <p class="text-earth-600 text-lg mb-8">
      The person or page you're looking for doesn't exist. Try searching below or browse all individuals.
    </p>
    <div class="max-w-xl mx-auto mb-8">
      <SearchWidget />
    </div>
    <a href="/browse" class="inline-block bg-sage-500 hover:bg-sage-600 text-white no-underline rounded-lg px-6 py-2.5 text-sm font-medium transition-colors">
      Browse All Individuals
    </a>
  </div>
</BaseLayout>
