---
import BaseLayout from '../layouts/BaseLayout.astro';
import PersonCard from '../components/PersonCard.astro';
import { getAllPeople, getAllSurnames } from '../lib/family-data';

const people = getAllPeople();
const surnames = getAllSurnames();
---

<BaseLayout title="Browse">
  <h1 class="text-3xl font-bold mb-6">Browse All Individuals</h1>

  <div class="mb-6 flex flex-wrap gap-3 items-end">
    <div>
      <label for="filter-surname" class="block text-sm text-earth-600 mb-1">Surname</label>
      <select id="filter-surname" class="bg-white border border-earth-300 rounded-lg px-3 py-2 text-sm text-earth-800">
        <option value="">All surnames</option>
        {surnames.map((s) => <option value={s}>{s}</option>)}
      </select>
    </div>
    <div>
      <label for="sort-by" class="block text-sm text-earth-600 mb-1">Sort by</label>
      <select id="sort-by" class="bg-white border border-earth-300 rounded-lg px-3 py-2 text-sm text-earth-800">
        <option value="name">Name (A–Z)</option>
        <option value="birth">Birth year</option>
      </select>
    </div>
    <p id="result-count" class="text-sm text-earth-500 ml-auto">{people.length} individuals</p>
  </div>

  <div id="people-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    {people
      .sort((a, b) => a.fullName.localeCompare(b.fullName))
      .map((person) => <PersonCard person={person} />)}
  </div>
</BaseLayout>

<script is:inline>
  const grid = document.getElementById('people-grid');
  const surnameFilter = document.getElementById('filter-surname');
  const sortBy = document.getElementById('sort-by');
  const resultCount = document.getElementById('result-count');

  // Read initial surname from URL
  const params = new URLSearchParams(window.location.search);
  const initialSurname = params.get('surname');
  if (initialSurname && surnameFilter) {
    surnameFilter.value = initialSurname;
  }

  function applyFilters() {
    if (!grid) return;
    const surname = surnameFilter?.value || '';
    const cards = [...grid.children];
    let visible = 0;

    cards.forEach((card) => {
      const cardSurname = card.getAttribute('data-surname') || '';
      const show = !surname || cardSurname === surname;
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    });

    if (resultCount) {
      resultCount.textContent = `${visible} individual${visible !== 1 ? 's' : ''}`;
    }
  }

  function applySort() {
    if (!grid) return;
    const sort = sortBy?.value || 'name';
    const cards = [...grid.children];

    cards.sort((a, b) => {
      if (sort === 'birth') {
        const aYear = parseInt(a.getAttribute('data-birth-year') || '9999', 10);
        const bYear = parseInt(b.getAttribute('data-birth-year') || '9999', 10);
        return aYear - bYear;
      }
      const aName = a.querySelector('h3')?.textContent || '';
      const bName = b.querySelector('h3')?.textContent || '';
      return aName.localeCompare(bName);
    });

    cards.forEach((card) => grid.appendChild(card));
  }

  surnameFilter?.addEventListener('change', applyFilters);
  sortBy?.addEventListener('change', () => { applySort(); applyFilters(); });

  // Apply initial filter
  applyFilters();
</script>
