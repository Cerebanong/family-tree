---
import type { Person } from '../lib/types';

interface Props {
  person: Person;
}

const { person } = Astro.props;
const yearRange = [person.birthYear, person.deathYear].filter(Boolean).join(' – ') || 'Dates unknown';
---

<a
  href={`/people/${person.slug}`}
  class="block no-underline bg-earth-100 border border-earth-200 rounded-lg p-4 hover:shadow-md hover:border-earth-300 transition-all"
  data-surname={person.name.last}
  data-birth-year={person.birthYear || ''}
  data-location={person.birth.place || ''}
>
  <h3 class="text-earth-800 font-serif text-base font-bold mb-1">{person.fullName}</h3>
  <p class="text-earth-600 text-sm mb-1">{yearRange}</p>
  <p class="text-earth-500 text-xs">{person.name.last} line</p>
</a>
